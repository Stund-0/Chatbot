# ============================================
# Configuración del Chatbot WhatsApp
# ============================================

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=chatbot123
WHATSAPP_API_VERSION=v22.0

# OpenAI (opcional, para interprete avanzado)
OPENAI_API_KEY=

# Administrador
ADMIN_TELEFONO=
ADMIN_CORREO=

# Base de datos: dejar vacío para SQLite local, o usar URL de PostgreSQL
DATABASE_URL=

# Autenticación para endpoints /reportes/*
REPORTES_API_KEY=

# Modo simulación = true para pruebas sin WhatsApp real
MODO_SIMULACION=true
DEBUG=false

# Logging: INFO, DEBUG, WARNING, ERROR
LOG_LEVEL=INFO
# Formato: json (producción) o text (desarrollo)
LOG_FORMAT=json
